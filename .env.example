# Postgres
POSTGRES_USER=shelfshare
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=shelfshare
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3000
DATABASE_URL=postgresql://shelfshare:change_me_in_production@postgres:5432/shelfshare?schema=public

NODE_ENV=development

# Frontend (pentru linkurile din email-uri si CORS)
FRONTEND_URL=http://localhost:8080

# JWT - genereaza secrete lungi si random, diferite intre ele
# Poti genera unul cu: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_generate_a_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_generate_a_different_random_secret
JWT_REFRESH_EXPIRY=30d

# Resend (email) - cheia se ia de pe resend.com dupa ce iti verifici domeniul
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=onboarding@resend.dev

# Google OAuth - se genereaza in Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
