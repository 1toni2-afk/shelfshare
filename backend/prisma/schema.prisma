// ShelfShare - Prisma Schema
// Milestone 2: câmpurile necesare pentru autentificare.
// Milestone 3: câmpurile de profil.
// Milestone 4: catalogul de cărți + biblioteca personală.
// Milestone 5: genre pentru filtrarea la căutare.
// Milestone 6: cererile de schimb.
// Milestone 7: conversații și mesaje.
// Milestone 8: wishlist + notificări.
// Milestone 9: câmpuri admin.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String?

  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?
  emailVerifyExpiry DateTime?

  resetPasswordToken  String?
  resetPasswordExpiry DateTime?

  refreshTokenHash String?

  googleId String? @unique

  name         String?
  username     String?  @unique
  nameVisible  Boolean  @default(true)
  city         String?
  bio          String?
  profileImage String?

  rating               Float @default(0)
  booksExchangedCount  Int   @default(0)
  booksSharedCount     Int   @default(0)
  booksReceivedCount   Int   @default(0)

  // Medii pe dimensiuni, calculate din ExchangeRequest.*RatingFor* - vezi
  // recomputeRating în exchanges.service.ts. Rămân 0 până la prima evaluare
  // primită pe dimensiunea respectivă (conditionRating poate rămâne 0 mult
  // timp, fiindcă se dă doar de cine chiar primește o carte, nu la orice
  // schimb - ex. un schimb cu bani în loc de carte).
  avgCommunicationRating Float @default(0)
  avgPunctualityRating   Float @default(0)
  avgConditionRating     Float @default(0)

  lastActiveAt DateTime?

  // Reading Streak - zile consecutive cu activitate (vezi JwtAuthGuard),
  // calculat pe zi calendaristică, nu pe fereastră de 24h.
  currentStreakDays Int      @default(0)
  longestStreakDays Int      @default(0)
  lastStreakDate    DateTime?

  // XP & Levels - punctele se acumulează la acțiuni cheie deja existente
  // (listare carte, schimb finalizat, vânzare acceptată, recenzie scrisă);
  // nivelul se calculează din xp, nu se stochează separat (vezi
  // levelForXp în profile.service.ts).
  xp Int @default(0)

  // Reading Challenge - obiectiv anual opțional, setat de user; progresul
  // se calculează din BookshelfEntry cu status FINISHED din anul curent,
  // nu e stocat separat.
  readingChallengeGoal Int?

  isAdmin  Boolean @default(false)
  isBanned Boolean @default(false)

  showAcquisitionHistory Boolean @default(false)

  referralCode String? @unique
  invitedById  String?
  invitedBy    User?   @relation("Referrals", fields: [invitedById], references: [id], onDelete: SetNull)
  referrals    User[]  @relation("Referrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBooks                UserBook[]
  sentExchangeRequests     ExchangeRequest[] @relation("RequesterExchanges")
  receivedExchangeRequests ExchangeRequest[] @relation("OwnerExchanges")
  conversationsAsUserA     Conversation[]    @relation("ConversationUserA")
  conversationsAsUserB     Conversation[]    @relation("ConversationUserB")
  messagesSent             Message[]         @relation("MessageSender")
  wishlistItems            WishlistItem[]
  notifications            Notification[]
  blocksMade               Block[]           @relation("BlockBlocker")
  blocksReceived           Block[]           @relation("BlockBlocked")
  reportsMade              Report[]          @relation("ReportReporter")
  reportsReceived          Report[]          @relation("ReportReported")
  offersMade               PriceOffer[]      @relation("OfferBuyer")
  offersReceived           PriceOffer[]      @relation("OfferOwner")
  following                Follow[]          @relation("FollowFollower")
  followers                Follow[]          @relation("FollowFollowing")
  feedback                 Feedback[]
  bookViews                BookView[]
  bookshelfEntries         BookshelfEntry[]
  auctionBids              Bid[]             @relation("AuctionBidder")
  auctionsWon              Auction[]         @relation("AuctionHighestBidder")
  auctionWatches           AuctionWatch[]

  @@map("users")
}

model Feedback {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  message String

  createdAt DateTime @default(now())

  @@map("feedback")
}

/// Mesaje de la useri care nu se pot loga (deci fără cont autentificat) -
/// trimise din ecranul de login, protejate cu un captcha simplu în loc de
/// serviciu extern (vezi support.service.ts).
model SupportRequest {
  id String @id @default(uuid())

  name    String
  email   String
  phone   String?
  message String

  createdAt DateTime @default(now())

  @@map("support_requests")
}

model Follow {
  id String @id @default(uuid())

  followerId String
  follower   User   @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId String
  following   User   @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("follows")
}

model Block {
  id String @id @default(uuid())

  blockerId String
  blocker   User   @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)

  blockedId String
  blocked   User   @relation("BlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

enum ReportReason {
  SPAM
  SCAM
  INAPPROPRIATE
  HARASSMENT
  OTHER
}

model Report {
  id String @id @default(uuid())

  reporterId String
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  reportedUserId String
  reportedUser   User   @relation("ReportReported", fields: [reportedUserId], references: [id], onDelete: Cascade)

  reason  ReportReason
  details String?

  userBookId String?
  userBook   UserBook? @relation(fields: [userBookId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("reports")
}

model UpcomingRelease {
  id String @id @default(uuid())

  title       String
  author      String?
  coverUrl    String?
  description String?
  isbn        String?
  releaseDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("upcoming_releases")
}

enum BookCondition {
  NOUA
  FOARTE_BUNA
  BUNA
  ACCEPTABILA
}

model Book {
  id String @id @default(uuid())

  isbn        String? @unique
  title       String
  author      String?
  description String?
  coverUrl    String?
  publisher   String?
  publishedYear Int?
  pageCount   Int?
  language    String?
  genre       String?

  referencePrice         Decimal? @db.Decimal(10, 2)
  referencePriceCurrency String?

  source String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBooks UserBook[]
  wishlistItems WishlistItem[]
  bookshelfEntries BookshelfEntry[]

  @@map("books")
}

model UserBook {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  condition        BookCondition
  language         String?
  edition          String?
  isHardcover      Boolean       @default(false)
  availableForSwap Boolean       @default(true)

  isForSale    Boolean  @default(false)
  salePrice    Decimal? @db.Decimal(10, 2)
  isNegotiable Boolean  @default(true)

  // Licitație (Milestone 3) - un al 4-lea tip de anunț, distinct de
  // isForSale/availableForSwap. Detaliile (preț curent, ofertant cel mai
  // mare, termen) stau pe modelul Auction, legat 1:1 - isAuction rămâne
  // doar ca flag rapid de filtrare la browse, fără să dubleze acele date.
  isAuction Boolean  @default(false)
  auction   Auction?

  viewCount Int @default(0)

  photos String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exchangeRequestsReceived ExchangeRequest[] @relation("RequestedBook")
  exchangeRequestsOffered  ExchangeRequest[] @relation("OfferedBook")
  priceOffers              PriceOffer[]
  reports                  Report[]
  bookViews                BookView[]

  // Lanțul de proveniență - dacă userul care a primit cartea (schimb/vânzare)
  // decide să o re-listeze, noul anunț ține minte anunțul din care provine,
  // ca istoricul să poată fi urmărit pe mai multe schimburi succesive.
  previousListingId String?
  previousListing   UserBook?  @relation("ListingChain", fields: [previousListingId], references: [id], onDelete: SetNull)
  nextListings      UserBook[] @relation("ListingChain")

  @@map("user_books")
}

enum AuctionStatus {
  ACTIVE
  ENDED
  CANCELLED
}

model Auction {
  id String @id @default(uuid())

  userBookId String   @unique
  userBook   UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  startingPrice Decimal  @db.Decimal(10, 2)
  reservePrice  Decimal? @db.Decimal(10, 2)
  buyNowPrice   Decimal? @db.Decimal(10, 2)

  // currentPrice = startingPrice cât timp nu există nicio licitație - se
  // actualizează la fiecare bid nou, ca să nu fie nevoie să recalculăm
  // MAX(bids.amount) la fiecare citire.
  currentPrice Decimal @db.Decimal(10, 2)

  highestBidderId String?
  highestBidder   User?   @relation("AuctionHighestBidder", fields: [highestBidderId], references: [id], onDelete: SetNull)

  // Anti-sniping: un bid în ultimele 5 minute împinge termenul cu încă 5
  // minute (se repetă cât timp tot vin bid-uri târzii) - vezi placeBid în
  // auctions.service.ts. endsAt e deci mutabil, nu doar setat la creare.
  endsAt DateTime
  status AuctionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bids    Bid[]
  watches AuctionWatch[]

  @@map("auctions")
}

/// Ofertele sunt anonime față de ceilalți licitatori (afișate ca "Ofertant
/// #N", ordinea primei apariții) dar vizibile integral pentru vânzător -
/// vezi anonymizeBids în auctions.service.ts. Nu există un preț minim de
/// increment - orice sumă strict mai mare decât currentPrice e validă.
model Bid {
  id String @id @default(uuid())

  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  bidderId String
  bidder   User   @relation("AuctionBidder", fields: [bidderId], references: [id], onDelete: Cascade)

  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@map("bids")
}

model AuctionWatch {
  id String @id @default(uuid())

  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([auctionId, userId])
  @@map("auction_watches")
}

/// O vizualizare a unei cărți de către un user autentificat - deduplicat
/// Termeni căutați (titlu-carte extern sau în bibliotecă), pentru "Popular
/// Searches" - un simplu log append-only, agregat la citire (vezi
/// getPopularSearches în books.service.ts), fără userId (nu ne interesează
/// cine a căutat, doar ce se caută des).
model SearchLog {
  id        String   @id @default(uuid())
  query     String
  createdAt DateTime @default(now())

  @@map("search_logs")
}

/// prin unique(userBookId, userId), ca refresh-urile repetate ale aceluiași
/// user să nu umfle numărul de vizitatori unici (viewCount de pe UserBook
/// rămâne totalul brut, cu tot cu refresh-uri).
model BookView {
  id         String   @id @default(uuid())
  userBookId String
  userBook   UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userBookId, userId])
  @@map("book_views")
}

enum BookshelfStatus {
  READING
  WANT_TO_READ
  FINISHED
}

/// "Public Bookshelf" - statusul personal de citit al userului pentru o
/// carte din catalog, INDIFERENT dacă are sau nu un exemplar fizic
/// listat (spre deosebire de UserBook, care înseamnă "dețin o copie fizică
/// și o pot da la schimb/vânzare"). Un user poate marca "Vreau să citesc"
/// o carte pe care nici măcar n-a văzut-o vreodată la schimb pe platformă.
/// "Shared" din roadmap nu are o intrare aici - se derivă direct din
/// UserBook.availableForSwap (vezi getPublicBookshelf), ca să nu dubleze o
/// stare care există deja.
model BookshelfEntry {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  status BookshelfStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId])
  @@map("bookshelf_entries")
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

model PriceOffer {
  id String @id @default(uuid())

  buyerId String
  buyer   User   @relation("OfferBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("OfferOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  userBookId String
  userBook   UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  amount  Decimal     @db.Decimal(10, 2)
  message String?
  status  OfferStatus @default(PENDING)

  // Expirare "leneșă" - nu există un job programat care baleiază periodic;
  // orice citire a unei oferte PENDING (getSentOffers/getReceivedOffers)
  // verifică expiresAt și trece oferta pe EXPIRED pe loc dacă a trecut
  // termenul, înainte de a răspunde. Simplu, fără dependință nouă
  // (@nestjs/schedule), suficient la scara aplicației.
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@map("price_offers")
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
  EXPIRED
}

model ExchangeRequest {
  id String @id @default(uuid())

  requesterId String
  requester   User   @relation("RequesterExchanges", fields: [requesterId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("OwnerExchanges", fields: [ownerId], references: [id], onDelete: Cascade)

  requestedBookId String
  requestedBook   UserBook @relation("RequestedBook", fields: [requestedBookId], references: [id], onDelete: Cascade)

  offeredBookId String?
  offeredBook   UserBook? @relation("OfferedBook", fields: [offeredBookId], references: [id], onDelete: SetNull)

  offeredAmount Decimal? @db.Decimal(10, 2)

  status  ExchangeStatus @default(PENDING)
  message String?

  // Expirare "leneșă" - vezi comentariul de pe PriceOffer.expiresAt.
  expiresAt DateTime?

  requesterRatingForOwner Int?
  ownerRatingForRequester Int?
  requesterReviewForOwner String?
  ownerReviewForRequester String?

  // Rating pe dimensiuni - Communication/Punctuality se pot da mereu în
  // ambele direcții; Condition se dă doar de partea care CHIAR a primit o
  // carte fizică (requester primește mereu requestedBook; owner primește
  // offeredBook doar dacă schimbul a fost carte-contra-carte, nu bani).
  requesterCommunicationForOwner Int?
  requesterPunctualityForOwner   Int?
  requesterConditionForOwner     Int?
  ownerCommunicationForRequester Int?
  ownerPunctualityForRequester   Int?
  ownerConditionForRequester     Int?

  meetingTime     DateTime?
  meetingLocation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exchange_requests")
}

model Conversation {
  id String @id @default(uuid())

  userAId String
  userA   User   @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)

  userBId String
  userB   User   @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@unique([userAId, userBId])
  @@map("conversations")
}

model Message {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  content  String?
  photo    String?
  location String?

  // Coordonate + oră propusă pentru întâlnire - setate doar pe mesajele de
  // locație (vezi "Trimite locația întâlnirii" din chat).
  locationLat Float?
  locationLng Float?
  meetingAt   DateTime?

  // Setat doar pe mesajul generat automat când cineva face o ofertă de preț
  // (vezi offers.service.ts#createOffer) - face oferta vizibilă și
  // acționabilă direct în chat, nu doar ca o notificare separată.
  priceOfferId String?
  priceOffer   PriceOffer? @relation(fields: [priceOfferId], references: [id], onDelete: SetNull)

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("messages")
}

model WishlistItem {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, bookId])
  @@map("wishlist_items")
}

enum NotificationType {
  WISHLIST_BOOK_AVAILABLE
  EXCHANGE_REQUEST_RECEIVED
  EXCHANGE_REQUEST_ACCEPTED
  EXCHANGE_REQUEST_REJECTED
  EXCHANGE_MEETING_SCHEDULED
  NEW_MESSAGE
  PRICE_OFFER_RECEIVED
  PRICE_OFFER_ACCEPTED
  PRICE_OFFER_REJECTED
  FOLLOWED_USER_NEW_BOOK
  NEARBY_BOOK_LISTED
  PRICE_CHANGED
  OUTBID
  AUCTION_WON
  AUCTION_ENDED
}

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  message String
  data    Json?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("notifications")
}
