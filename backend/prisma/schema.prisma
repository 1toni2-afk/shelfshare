// ShelfShare - Prisma Schema
// Milestone 2: câmpurile necesare pentru autentificare.
// Milestone 3: câmpurile de profil.
// Modelele Books, UserBooks, ExchangeRequests, Messages, Reviews, Wishlist etc.
// se adaugă la milestone-urile corespunzătoare, nu acum.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String? // null dacă userul s-a înregistrat doar prin Google

  // Verificare email
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?   @unique
  emailVerifyExpiry DateTime?

  // Reset parolă
  resetPasswordToken  String?   @unique
  resetPasswordExpiry DateTime?

  // Refresh token curent (hash-uit), pentru invalidare la logout
  refreshTokenHash String?

  // Google OAuth
  googleId String? @unique

  // Profil
  name         String?
  city         String?
  bio          String?
  profileImage String? // path către poza din MinIO - se adaugă la Milestone 4

  // Calculate din alte module (reviews, exchanges) - încă neimplementate.
  // Rămân aici ca placeholder, cu valoare default, până construim acele module.
  rating               Float @default(0)
  booksExchangedCount  Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
