// ShelfShare - Prisma Schema
// Milestone 2: câmpurile necesare pentru autentificare.
// Milestone 3: câmpurile de profil.
// Milestone 4: catalogul de cărți + biblioteca personală.
// Milestone 5: genre pentru filtrarea la căutare.
// Milestone 6: cererile de schimb.
// Milestone 7: conversații și mesaje.
// Milestone 8: wishlist + notificări.
// Milestone 9: câmpuri admin.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String?

  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?
  emailVerifyExpiry DateTime?

  resetPasswordToken  String?   @unique
  resetPasswordExpiry DateTime?

  refreshTokenHash String?

  googleId String? @unique

  name         String?
  username     String?  @unique
  nameVisible  Boolean  @default(true)
  city         String?
  bio          String?
  profileImage String?

  rating               Float @default(0)
  booksExchangedCount  Int   @default(0)

  isAdmin  Boolean @default(false)
  isBanned Boolean @default(false)

  showAcquisitionHistory Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBooks                UserBook[]
  sentExchangeRequests     ExchangeRequest[] @relation("RequesterExchanges")
  receivedExchangeRequests ExchangeRequest[] @relation("OwnerExchanges")
  conversationsAsUserA     Conversation[]    @relation("ConversationUserA")
  conversationsAsUserB     Conversation[]    @relation("ConversationUserB")
  messagesSent             Message[]         @relation("MessageSender")
  wishlistItems            WishlistItem[]
  notifications            Notification[]
  blocksMade               Block[]           @relation("BlockBlocker")
  blocksReceived           Block[]           @relation("BlockBlocked")
  reportsMade              Report[]          @relation("ReportReporter")
  reportsReceived          Report[]          @relation("ReportReported")
  offersMade               PriceOffer[]      @relation("OfferBuyer")
  offersReceived           PriceOffer[]      @relation("OfferOwner")
  following                Follow[]          @relation("FollowFollower")
  followers                Follow[]          @relation("FollowFollowing")
  feedback                 Feedback[]
  bookViews                BookView[]

  @@map("users")
}

model Feedback {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  message String

  createdAt DateTime @default(now())

  @@map("feedback")
}

model Follow {
  id String @id @default(uuid())

  followerId String
  follower   User   @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId String
  following   User   @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("follows")
}

model Block {
  id String @id @default(uuid())

  blockerId String
  blocker   User   @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)

  blockedId String
  blocked   User   @relation("BlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

enum ReportReason {
  SPAM
  SCAM
  INAPPROPRIATE
  HARASSMENT
  OTHER
}

model Report {
  id String @id @default(uuid())

  reporterId String
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  reportedUserId String
  reportedUser   User   @relation("ReportReported", fields: [reportedUserId], references: [id], onDelete: Cascade)

  reason  ReportReason
  details String?

  userBookId String?
  userBook   UserBook? @relation(fields: [userBookId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("reports")
}

model UpcomingRelease {
  id String @id @default(uuid())

  title       String
  author      String?
  coverUrl    String?
  description String?
  isbn        String?
  releaseDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("upcoming_releases")
}

enum BookCondition {
  NOUA
  FOARTE_BUNA
  BUNA
  ACCEPTABILA
}

model Book {
  id String @id @default(uuid())

  isbn        String? @unique
  title       String
  author      String?
  description String?
  coverUrl    String?
  publisher   String?
  publishedYear Int?
  pageCount   Int?
  language    String?
  genre       String?

  referencePrice         Decimal? @db.Decimal(10, 2)
  referencePriceCurrency String?

  source String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBooks UserBook[]
  wishlistItems WishlistItem[]

  @@map("books")
}

model UserBook {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  condition        BookCondition
  language         String?
  edition          String?
  isHardcover      Boolean       @default(false)
  availableForSwap Boolean       @default(true)

  isForSale    Boolean  @default(false)
  salePrice    Decimal? @db.Decimal(10, 2)
  isNegotiable Boolean  @default(true)

  viewCount Int @default(0)

  photos String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exchangeRequestsReceived ExchangeRequest[] @relation("RequestedBook")
  exchangeRequestsOffered  ExchangeRequest[] @relation("OfferedBook")
  priceOffers              PriceOffer[]
  reports                  Report[]
  bookViews                BookView[]

  // Lanțul de proveniență - dacă userul care a primit cartea (schimb/vânzare)
  // decide să o re-listeze, noul anunț ține minte anunțul din care provine,
  // ca istoricul să poată fi urmărit pe mai multe schimburi succesive.
  previousListingId String?
  previousListing   UserBook?  @relation("ListingChain", fields: [previousListingId], references: [id], onDelete: SetNull)
  nextListings      UserBook[] @relation("ListingChain")

  @@map("user_books")
}

/// O vizualizare a unei cărți de către un user autentificat - deduplicat
/// prin unique(userBookId, userId), ca refresh-urile repetate ale aceluiași
/// user să nu umfle numărul de vizitatori unici (viewCount de pe UserBook
/// rămâne totalul brut, cu tot cu refresh-uri).
model BookView {
  id         String   @id @default(uuid())
  userBookId String
  userBook   UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userBookId, userId])
  @@map("book_views")
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model PriceOffer {
  id String @id @default(uuid())

  buyerId String
  buyer   User   @relation("OfferBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("OfferOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  userBookId String
  userBook   UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  amount  Decimal     @db.Decimal(10, 2)
  message String?
  status  OfferStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("price_offers")
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

model ExchangeRequest {
  id String @id @default(uuid())

  requesterId String
  requester   User   @relation("RequesterExchanges", fields: [requesterId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("OwnerExchanges", fields: [ownerId], references: [id], onDelete: Cascade)

  requestedBookId String
  requestedBook   UserBook @relation("RequestedBook", fields: [requestedBookId], references: [id], onDelete: Cascade)

  offeredBookId String?
  offeredBook   UserBook? @relation("OfferedBook", fields: [offeredBookId], references: [id], onDelete: SetNull)

  offeredAmount Decimal? @db.Decimal(10, 2)

  status  ExchangeStatus @default(PENDING)
  message String?

  requesterRatingForOwner Int?
  ownerRatingForRequester Int?
  requesterReviewForOwner String?
  ownerReviewForRequester String?

  meetingTime     DateTime?
  meetingLocation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exchange_requests")
}

model Conversation {
  id String @id @default(uuid())

  userAId String
  userA   User   @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)

  userBId String
  userB   User   @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@unique([userAId, userBId])
  @@map("conversations")
}

model Message {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  content  String?
  photo    String?
  location String?

  // Coordonate + oră propusă pentru întâlnire - setate doar pe mesajele de
  // locație (vezi "Trimite locația întâlnirii" din chat).
  locationLat Float?
  locationLng Float?
  meetingAt   DateTime?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("messages")
}

model WishlistItem {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, bookId])
  @@map("wishlist_items")
}

enum NotificationType {
  WISHLIST_BOOK_AVAILABLE
  EXCHANGE_REQUEST_RECEIVED
  EXCHANGE_REQUEST_ACCEPTED
  EXCHANGE_REQUEST_REJECTED
  EXCHANGE_MEETING_SCHEDULED
  NEW_MESSAGE
  PRICE_OFFER_RECEIVED
  PRICE_OFFER_ACCEPTED
  PRICE_OFFER_REJECTED
  FOLLOWED_USER_NEW_BOOK
}

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  message String
  data    Json?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("notifications")
}
