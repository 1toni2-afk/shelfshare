FROM node:22-alpine

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .
# Nu rulăm "prisma generate" aici: la build-time nu există încă DATABASE_URL
# (variabilele din docker-compose sunt injectate doar la pornirea containerului).
# Îl rulăm în docker-compose.yml, ca parte din "command", chiar înainte de pornirea serverului.

EXPOSE 3000

CMD ["pnpm", "run", "start:dev"]
